# ═══════════════════════════════════════════════════════════════
#  ZETABUS · variables de entorno
#  Copia este fichero a .env.local y rellena los valores.
#  .env.local ESTÁ IGNORADO POR GIT. Nunca lo subas.
# ═══════════════════════════════════════════════════════════════

# ApiKey del Punto de Acceso Nacional (NAP), necesaria SOLO para
# descargar el GTFS. No se usa en tiempo de ejecución.
#
# Cómo conseguirla:
#   1. Registro gratuito en https://nap.transportes.gob.es
#   2. La ApiKey se emite al instante en tu perfil
#   3. Ver data/gtfs/README.md para el comando de descarga
NAP_API_KEY=

# Correo de contacto que ZETABUS envía en su User-Agent al consultar
# los servicios de Avanza. Si molestamos, queremos que puedan pedirnos
# que paremos ANTES de bloquearnos. Ver README.md · "Sobre el scraping".
ZETABUS_CONTACT_EMAIL=
