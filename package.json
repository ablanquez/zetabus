{
  "name": "zetabus",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "npm run data:build && npm run correspondencias:ensure && next build",
    "start": "next start",
    "lint": "eslint",
    "lint:fix": "eslint --fix",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "gtfs:fetch": "tsx scripts/fetch-gtfs.ts",
    "data:build": "tsx scripts/build-data.ts",
    "canario": "tsx scripts/canario.ts",
    "peticiones": "tsx scripts/peticiones.ts",
    "campo": "tsx scripts/campo.ts",
    "paso": "tsx scripts/paso.ts",
    "visual": "playwright test",
    "visual:instrumento": "playwright test e2e/instrumento.spec.ts",
    "auditoria": "playwright test e2e/auditoria --project=360px --grep-invert=NUNCA",
    "flota:build": "tsx scripts/build-flota.ts",
    "nombres:build": "tsx scripts/build-nombres.ts",
    "correspondencias:build": "tsx scripts/build-correspondencias.ts",
    "correspondencias:ensure": "tsx scripts/ensure-correspondencias.ts",
    "skill:setup": "node scripts/setup-skill.mjs"
  },
  "dependencies": {
    "leaflet": "^1.9.4",
    "next": "16.2.10",
    "node-html-parser": "^9.0.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-leaflet": "^5.0.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@tailwindcss/postcss": "^4",
    "@types/leaflet": "^1.9.21",
    "@types/node": "^20",
    "@types/pngjs": "^6.0.5",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "dotenv": "^17",
    "eslint": "^9",
    "eslint-config-next": "16.2.10",
    "fflate": "^0.8",
    "pngjs": "^7.0.0",
    "tailwindcss": "^4",
    "tsx": "^4",
    "typescript": "^5",
    "vitest": "^3"
  },
  "description": "Visor en vivo del autobús urbano de Zaragoza",
  "license": "Apache-2.0",
  "engines": {
    "node": ">=20.9"
  }
}
